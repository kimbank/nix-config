# Copy this file to scripts/github-local-auth.env and adjust values.
#
# Required format:
#   GITHUB_<n>="bucket|vault|gh_item|ssh_item|git_name|git_email"
#
# Required segments:
# - bucket: directory under ~/Github
# - vault: 1Password vault name
# - gh_item: 1Password item containing the GitHub token
# - ssh_item: 1Password SSH key item containing the public key
#
# Optional segments:
# - git_name, git_email: only set these for buckets that should override author identity.
#   If you set one, set both. Order matters: ...|git_name|git_email
#
# Optional per-entry overrides:
# - GITHUB_<n>_TOKEN_FIELD: defaults to "token"
# - GITHUB_<n>_PUBLIC_KEY_FIELD: defaults to "public key"

GITHUB_1="kimbank|Develop|github-kimbank-gh|github-kimbank|kimbank|kimeunhang@proton.me"
GITHUB_1_TOKEN_FIELD="token"
GITHUB_1_PUBLIC_KEY_FIELD="public key"

GITHUB_2="kimbank2|Work|github-kimbank2-gh|github-kimbank2||"

GITHUB_3="kimbank3|Family|github-kimbank3-gh|github-kimbank3||"
