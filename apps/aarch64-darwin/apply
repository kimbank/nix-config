#!/usr/bin/env bash

set -euo pipefail

GREEN='\033[1;32m'
YELLOW='\033[1;33m'
RED='\033[1;31m'
NC='\033[0m'

print_msg() {
  echo -e "$1"
}

prompt() {
  local message="$1"
  local variable="$2"

  print_msg "$message"
  read -r "$variable"
}

escape_replacement() {
  printf '%s' "$1" | sed -e 's/[&|\\]/\\&/g'
}

USERNAME="$(whoami)"
GIT_NAME="$(git config --get user.name || true)"
GIT_EMAIL="$(git config --get user.email || true)"

if [[ "$USERNAME" == "root" ]]; then
  prompt "${YELLOW}Running as root. Enter the target username:${NC}" USERNAME
fi

if [[ -z "$GIT_NAME" ]]; then
  prompt "${YELLOW}Enter your git user.name:${NC}" GIT_NAME
fi

if [[ -z "$GIT_EMAIL" ]]; then
  prompt "${YELLOW}Enter your git user.email:${NC}" GIT_EMAIL
fi

print_msg "${GREEN}Username:${NC} $USERNAME"
print_msg "${GREEN}Name:${NC} $GIT_NAME"
print_msg "${GREEN}Email:${NC} $GIT_EMAIL"

choice="${APPLY_CONFIRM:-}"
if [[ -z "$choice" ]]; then
  prompt "${YELLOW}Apply these values to the repo? yes/no:${NC}" choice
fi

case "$choice" in
  [Yy] | [Yy][Ee][Ss] )
    ;;
  * )
    print_msg "${RED}Aborted.${NC}"
    exit 1
    ;;
esac

replace_tokens() {
  local file="$1"
  local user_escaped
  local name_escaped
  local email_escaped

  user_escaped="$(escape_replacement "$USERNAME")"
  name_escaped="$(escape_replacement "$GIT_NAME")"
  email_escaped="$(escape_replacement "$GIT_EMAIL")"

  LC_ALL=C LANG=C sed -i '' \
    -e "s|loginUser = \"kimbank\";|loginUser = \"$user_escaped\";|g" \
    -e "s|name = \"kimbank\";|name = \"$name_escaped\";|g" \
    -e "s|email = \"kimeunhang@proton.me\";|email = \"$email_escaped\";|g" \
    "$file"
}

export USERNAME GIT_NAME GIT_EMAIL
export -f escape_replacement replace_tokens

find . \
  -type f \
  -not -path './.git/*' \
  -not -name 'flake.lock' \
  -exec bash -c 'replace_tokens "$0"' {} \;

print_msg "${GREEN}Template values applied.${NC}"
