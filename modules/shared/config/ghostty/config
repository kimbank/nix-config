# cmux reads ~/.config/ghostty/config, so keep the primary config here.
# Browse built-in themes:
# - Ghostty docs: https://ghostty.org/docs/features/theme
# - Theme gallery: https://iterm2colorschemes.com/

# Change this one line when you want a different dark/light pair later.
# Example:
# theme = dark:Catppuccin Frappe,light:Catppuccin Latte
theme = dark:kimbank-ashes-dark,light:kimbank-ashes-light

# Keep Latin text close to WezTerm's default feel, but map Hangul to a crisper
# system font so Korean text doesn't inherit D2Coding's softer glyphs.
font-family = ""
font-family = JetBrains Mono
# for map Korean font to Apple SD Gothic Neo
# font-codepoint-map = U+1100-U+11FF,U+3130-U+318F,U+A960-U+A97F,U+AC00-U+D7AF,U+D7B0-U+D7FF=Apple SD Gothic Neo
font-size = 14

# Keep window chrome aligned with the active macOS appearance.
window-theme = system

# Give pane-heavy cmux sessions a little breathing room.
window-padding-x = 6
window-padding-y = 6

scrollback-limit = 50000
